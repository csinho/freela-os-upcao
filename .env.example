# Copie para .env na máquina local (não commitar o .env).
# No EasyPanel: cadastre as MESMAS variáveis na etapa de build do app.

# URL do projeto Supabase (Settings → API → Project URL)
VITE_SUPABASE_URL=https://SEU_PROJETO.supabase.co

# Chave pública (Settings → API → publishable key ou anon key legada)
VITE_SUPABASE_PUBLISHABLE_KEY=sua_publishable_key_aqui
